{
  "appId": "com.goodsapp.collector",
  "appName": "谷子收纳",
  "webDir": "dist",
  "android": {
    "allowMixedContent": true,
    "captureInput": false
  },
  "plugins": {
    "CapacitorHttp": {
      "enabled": true
    },
    "CapacitorUpdater": {
      "autoUpdate": false,
      "appReadyTimeout": 15000,
      "autoDeleteFailed": true,
      "autoDeletePrevious": true,
      "resetWhenUpdate": true
    },
    "CapacitorSQLite": {
      "androidIsEncryption": false,
      "androidBiometric": {
        "biometricAuth": false
      }
    }
  }
}
