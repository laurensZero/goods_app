<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0B1220"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#111827"
        android:elevation="6dp"
        android:gravity="center_vertical"
        android:minHeight="56dp"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingTop="8dp"
        android:paddingEnd="12dp"
        android:paddingBottom="8dp">

        <Button
            android:id="@+id/mihoyo_close_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:backgroundTint="#374151"
            android:minHeight="40dp"
            android:text="关闭"
            android:textAllCaps="false"
            android:textColor="#F9FAFB" />

        <TextView
            android:id="@+id/mihoyo_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="登录米游铺并读取订单"
            android:textColor="#F9FAFB"
            android:textSize="16sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/mihoyo_action_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:backgroundTint="#2563EB"
            android:minHeight="40dp"
            android:text="继续导入"
            android:textAllCaps="false"
            android:textColor="#FFFFFF" />
    </LinearLayout>

    <TextView
        android:id="@+id/mihoyo_hint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#111827"
        android:paddingStart="12dp"
        android:paddingTop="0dp"
        android:paddingEnd="12dp"
        android:paddingBottom="10dp"
        android:text="登录完成后点击右上角“继续导入”。登录态会保留在 App 内，下次可继续复用。"
        android:textColor="#CBD5E1"
        android:textSize="12sp" />

    <ProgressBar
        android:id="@+id/mihoyo_progress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:indeterminate="false"
        android:max="100"
        android:progress="0"
        android:progressTint="#60A5FA" />

    <WebView
        android:id="@+id/mihoyo_webview"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#FFFFFF" />
</LinearLayout>
